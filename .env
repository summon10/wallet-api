
POSTGRES_DB=walletdb-test
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet
POSTGRES_PORT=5432
DB_URL="jdbc:postgresql://postgres:${POSTGRES_PORT}/${POSTGRES_DB}"

TOMCAT_MAX_THREADS=400
TOMCAT_MIN_THREADS=20
TOMCAT_ACCEPT_COUNT=200
TOMCAT_MAX_CONNECTIONS=10000

SERVER_PORT=8080
LOG_LEVEL=INFO
JPA_SHOW_SQL=false
LIQUIBASE_ENABLED=true

DB_POOL_SIZE=50
DB_POOL_MIN_IDLE=10
DB_CONNECTION_TIMEOUT=30000
DB_MAX_LIFETIME=1800000